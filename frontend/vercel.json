{
  "redirects": [
    {
      "source": "/services/BasicEngineering",
      "destination": "/services/basic-engineering",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_BACKEND_URL/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
